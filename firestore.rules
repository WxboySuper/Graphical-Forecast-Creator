rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /userEntitlements/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /userMetrics/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /cloudCycles/{cycleId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
    }

    match /adminDailyMetrics/{documentId} {
      allow read, write: if false;
    }

    match /adminMetricDedupes/{documentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
